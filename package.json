{
  "name": "tidb-prisma-vercel-demo",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && next build",
    "dev": "next dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "setup": "NODE_OPTIONS='--experimental-json-modules' node ./scripts/setup.mjs",
    "start": "next start",
    "vercel-build": "export DATABASE_URL=$(node ./scripts/env.mjs) && yarn run prisma:deploy && yarn run setup && yarn run build"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@mui/lab": "^9.0.0-alpha.3",
    "@prisma/client": "^6.19.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "lodash": "^4.17.23",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "notistack": "^3.0.2",
    "postcss": "^8.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "recoil": "^0.7.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "eslint": "10.0.3",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "packageManager": "yarn@4.3.1+sha512.af78262d7d125afbfeed740602ace8c5e4405cd7f4735c08feb327286b2fdb2390fbca01589bfd1f50b1240548b74806767f5a063c94b67e431aabd0d86f7774",
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
